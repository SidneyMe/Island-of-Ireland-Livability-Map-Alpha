# Copy this file to .env and replace placeholders with local values.

# Option A: single SQLAlchemy/PostGIS connection URL.
DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/database_name

# Option B: split PostgreSQL connection settings.
# Comment out DATABASE_URL above if you prefer these values.
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_DB=database_name
# POSTGRES_USER=user
# POSTGRES_PASSWORD=password

# Optional local tool overrides.
OSM2PGSQL_BIN=osm2pgsql
WALKGRAPH_BIN=walkgraph/target/release/walkgraph.exe
