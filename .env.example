# Copy this file to .env and replace placeholders with local values.

# Option A: single SQLAlchemy/PostGIS connection URL.
DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/database_name

# Option B: split PostgreSQL connection settings.
# Comment out DATABASE_URL above if you prefer these values.
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_DB=database_name
# POSTGRES_USER=user
# POSTGRES_PASSWORD=password

# Optional local tool overrides.
OSM2PGSQL_BIN=osm2pgsql
# osm2pgsql memory tuning. Defaults run in-RAM with a 2048 MB node cache
# (~3 GB peak including osm2pgsql overhead) — fits comfortably in laptops
# with 8 GB+ free and is much faster than the disk-backed alternative.
# If you hit `bad allocation` or are memory-constrained, opt into the
# disk-backed flat-nodes file (~1GB, slower but low-RAM):
# OSM2PGSQL_FLAT_NODES=osm/flat-nodes.bin
# OSM2PGSQL_CACHE_MB=2048
# OSM2PGSQL_NUMBER_PROCESSES=1
# Windows:
# WALKGRAPH_BIN=walkgraph/target/release/walkgraph.exe
# Linux/macOS:
# WALKGRAPH_BIN=walkgraph/target/release/walkgraph

# Optional GTFS Phase 1 inputs.
# Local zip paths are the primary ingestion path. URL values are optional and
# are only used when you want the pipeline to refresh the local zip first.
# GTFS_NTA_ZIP_PATH=gtfs/nta_gtfs.zip
# GTFS_TRANSLINK_ZIP_PATH=gtfs/translink_gtfs.zip
# GTFS_NTA_URL=https://example.invalid/nta.zip
# GTFS_TRANSLINK_URL=https://example.invalid/translink.zip
# GTFS_AS_OF_DATE=2026-04-14
# GTFS_ANALYSIS_WINDOW_DAYS=30
# GTFS_SERVICE_DESERT_WINDOW_DAYS=7
# GTFS_MATCH_RADIUS_M=40

# Noise engine (default: artifact — no env var needed for normal use).
#
# artifact (DEFAULT): fast direct-copy from canonical artifact tables; does not read
#   raw noise ZIP/FileGDB files during precompute. Build artifact once, then reuse.
#   Normal flow:
#     python -m noise_artifacts --force
#     python main.py --precompute --force-precompute
#   Or let precompute auto-build the artifact if none exists:
#     python main.py --precompute --force-precompute
#
# legacy: slow debug path. Reads raw noise ZIP/FileGDB on every build and runs
#   full PostGIS materialization (~520k rows, 49 group-rounds). For debugging only.
#   PowerShell: $env:NOISE_MODE="legacy"; python main.py --precompute --force-precompute
#   CMD:        set NOISE_MODE=legacy&& python main.py --precompute --force-precompute
#
# NOISE_MODE=artifact   # already the default; uncomment only to be explicit
# NOISE_MODE=legacy     # uncomment only for debug/comparison work

# Noise artifact source ingest mode:
# - auto: prefer ogr2ogr direct-to-PostGIS when available, fallback to Python COPY staging
# - ogr2ogr: require ogr2ogr on PATH
# - python: force Python loader + COPY staging fallback path
# NOISE_INGEST_MODE=ogr2ogr
# Hard timeout for every ogr2ogr command to prevent infinite hangs.
# NOISE_OGR2OGR_TIMEOUT_SECONDS=300

# Python COPY fallback tuning (rows):
# NOISE_INGEST_COPY_BATCH_ROWS=5000
# NOISE_INGEST_FLUSH_ROWS=25000

# Road GDB canonical cache + normalize batching:
# NOISE_ROAD_GDB_CANONICAL_CACHE=1
# NOISE_REBUILD_ROAD_GDB_CACHE=0
# NOISE_ROAD_NORMALIZE_BATCH_SIZE=5000
# NOISE_SQL_STATEMENT_TIMEOUT_SECONDS=900
# NOISE_SQL_LOCK_TIMEOUT_SECONDS=30
#
# Legacy direct FileGDB worker tuning is deprecated/unsafe on Windows:
# Windows stable default (if legacy direct path is forced):
# NOISE_OGR2OGR_GDB_WORKERS=1
# NOISE_OGR2OGR_GDB_CHUNK_SIZE=25
# NOISE_OGR2OGR_FID_START=0
# Experimental only:
# NOISE_OGR2OGR_GDB_WORKERS=2

# Safety guards for Road GDB staging imports:
# NOISE_MIN_FREE_DISK_GB=30
# NOISE_KEEP_FAILED_STAGE_TABLES=0
# Debug only. Terminate stale PostgreSQL sessions from prior crashed runs.
# NOISE_TERMINATE_STALE_IMPORT_BACKENDS=0
# NOISE_TERMINATE_STALE_STAGE_LOCKS=0

# Legacy single-file candidate cache fallback is disabled by default.
# Set to 1 only for short-lived compatibility debugging.
# NOISE_ALLOW_LEGACY_CANDIDATE_CACHE=0
